{
  "name": "maintenance-scheduler-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "next dev --port 3000",
    "build:frontend": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "build": "npm run build:api && npm run build:frontend",
    "deploy": "wrangler publish"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "next-pwa": "^5.6.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
