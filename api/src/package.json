{
  "name": "maintenance-scheduler-api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:api": "wrangler dev --env development",
    "build:api": "tsc --outDir api/dist && node -e \"import('esbuild').then(e => e.default.buildSync({entryPoints: ['api/dist/index.js'], bundle: true, platform: 'browser', outfile: 'api/dist/bundled.js', format: 'esm'}))\"",
    "deploy:api": "wrangler publish --env production",
    "migrate": "wrangler d1 execute maintenance-scheduler --file=./migrations/001_init.sql",
    "migrate:preview": "wrangler d1 execute maintenance-scheduler --remote --file=./migrations/001_init.sql",
    "types": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "jose": "^5.0.0",
    "zod": "^3.22.0",
    "nanoid": "^5.0.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "wrangler": "^3.45.0",
    "typescript": "^5.3.0",
    "@cloudflare/workers-types": "^4.20231219.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
