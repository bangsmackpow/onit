{
  "name": "maintenance-scheduler",
  "version": "0.1.0",
  "description": "Serverless multi-tenant maintenance scheduling app on Cloudflare",
  "private": true,
  "workspaces": [
    "api",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "npm run dev:api --workspace=api",
    "dev:frontend": "npm run dev:frontend --workspace=frontend",
    "build": "npm run build --workspace=api && npm run build --workspace=frontend",
    "build:api": "npm run build:api --workspace=api",
    "build:frontend": "npm run build:frontend --workspace=frontend",
    "deploy": "npm run deploy:api && npm run deploy:frontend",
    "deploy:api": "npm run deploy:api --workspace=api",
    "deploy:frontend": "npm run deploy:frontend --workspace=frontend",
    "migrate": "npm run migrate --workspace=api",
    "migrate:preview": "npm run migrate:preview --workspace=api",
    "types": "npm run types --workspace=api",
    "lint": "npm run lint --workspace=api && npm run lint --workspace=frontend",
    "test": "npm run test --workspaces",
    "clean": "rm -rf api/dist api/node_modules frontend/.next frontend/node_modules node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/maintenance-scheduler.git"
  },
  "keywords": [
    "maintenance",
    "scheduling",
    "cloudflare",
    "serverless",
    "saas",
    "multi-tenant"
  ],
  "author": "Your Name",
  "license": "MIT"
}
